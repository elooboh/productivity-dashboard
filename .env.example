# Neon Postgres connection string.
# Get this from your Neon project dashboard (Connection Details > Pooled connection).
# On Vercel, add this in Project Settings > Environment Variables, or use the
# Vercel + Neon integration which sets it automatically.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Google Calendar integration (OAuth 2.0).
# Create these in Google Cloud Console → APIs & Services → Credentials →
# "OAuth client ID" (Web application). See README for the full walkthrough.
# The redirect URI is derived automatically from the request origin, so you do
# NOT set it here — you register it in the Console instead:
#   http://localhost:3000/api/google/callback   (local)
#   https://YOUR-APP.vercel.app/api/google/callback   (production)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
